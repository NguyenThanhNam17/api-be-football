APP_NAME=Football Booking
PORT=5555

MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database
SECRET=replace_with_a_strong_jwt_secret
OTP_SECRET=replace_with_a_strong_otp_secret
OTP_CODE_LENGTH=6
OTP_EXPIRES_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RESEND_SECONDS=60

MAIL_PROVIDER=SMTP
MAIL_VERIFY_CACHE_MS=60000

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_CONNECTION_TIMEOUT_MS=15000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=20000
SMTP_ADDRESS_FAMILY=4
SMTP_SERVICE=
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=your_email@gmail.com
SMTP_DEBUG=false

RESEND_API_KEY=
RESEND_FROM=
RESEND_REPLY_TO=
RESEND_API_URL=https://api.resend.com/emails
RESEND_TIMEOUT_MS=15000
